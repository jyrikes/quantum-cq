include README.md
include LICENSE
include pyproject.toml
include tests/conftest.py
recursive-include tests *.py
recursive-include docs *.md
include notebooks/quantum_cq_full_pipeline_navigation.ipynb
include notebooks/quantum_cq_getting_started.ipynb
include notebooks/quantum_cq_ibm_real_smoke.ipynb
include notebooks/quantum_cq_simple_api_lab.ipynb
prune .pytest_cache
prune .vscode
prune logs
prune results
prune notebooks/experiments
prune build
prune dist
prune src/quantum_cq.egg-info
recursive-exclude src/quantum_cq.egg-info *
exclude src/quantum_cq.egg-info/SOURCES.txt
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.pyo
global-exclude *.log
global-exclude *.executed.ipynb
global-exclude .env
global-exclude *.env
global-exclude .env.*
global-exclude .pypirc
